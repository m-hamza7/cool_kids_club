# Aiven PostgreSQL connection string
DATABASE_URL=postgres://user:password@host:port/dbname?uselibpqcompat=true&sslmode=require

# Secret for signing JWT tokens (use a long random string)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

PORT=3001
NODE_ENV=development

# Email OTP (SMTP) — use Gmail app password or any SMTP provider
# If not set, OTPs are logged to console in dev mode
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Cool Kids Club <your-email@gmail.com>

# Phone OTP (Twilio) — optional, if not set phone OTPs are logged to console
TWILIO_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1234567890
